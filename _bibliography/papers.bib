@inproceedings{islam2026solar,
  abbr        = {IEEE},
  bibtex_show = {true},
  title       = {Advanced Hybrid Deep Learning Models for Solar Energy Holding Capacity Prediction in Bangladesh},
  author      = {Islam, Aminul and Rahman, S. M. Obaydur and Hossin, Akbar and Sharika, Rubaia},
  booktitle   = {2026 IEEE 2nd International Conference on Quantum Photonics, Artificial Intelligence, and Networking (QPAIN)},
  pages       = {1--6},
  year        = {2026},
  month       = {April},
  address     = {Chittagong, Bangladesh},
  publisher   = {IEEE},
  doi         = {10.1109/QPAIN},
  abstract    = {Bangladesh receives a significant amount of solar energy throughout the year, making it an ideal location to produce a substantial amount of solar energy. However, in many regions, the actual amount of solar energy produced is often lower than the amount installed due to unforeseen weather conditions and seasonal variations. This study introduces a hybrid stacking ensemble approach combining Random Forest, XGBoost, Gradient Boosting, and AdaBoost with an MLP meta-learner to predict solar energy holding capacity. The model achieves up to 95% accuracy and outperforms all individual base models, supporting efficient renewable energy planning and policy-making in Bangladesh.},
  keywords    = {deep learning, ensemble learning, solar energy, energy forecasting, Bangladesh, hybrid model, MLP},
  selected    = {true}
}

@article{reshad2021curcuminoids,
  abbr        = {EJMHG},
  bibtex_show = {true},
  title       = {In silico investigations on curcuminoids from {Curcuma longa} as positive regulators of the {Wnt/$\beta$-catenin} signaling pathway in wound healing},
  author      = {Reshad, R. A. I. and Alam, S. and Raihan, H. B. and Meem, K. N. and Rahman, F. and Zahid, F. and Rafid, M. I. and Rahman, S. M. Obaydur and Omit, S. and Ali, M. H.},
  journal     = {Egyptian Journal of Medical Human Genetics},
  volume      = {22},
  number      = {65},
  year        = {2021},
  month       = {July},
  publisher   = {Springer},
  doi         = {10.1186/s43042-021-00182-9},
  url         = {https://link.springer.com/article/10.1186/s43042-021-00182-9},
  html        = {https://link.springer.com/article/10.1186/s43042-021-00182-9},
  abstract    = {Curcuminoids from Curcuma longa were investigated via in silico molecular docking as positive regulators of key proteins in the Wnt/β-catenin signaling pathway. The study highlights the potential of curcuminoids in promoting wound healing through computational predictive modeling of genetic pathways.},
  keywords    = {wound healing, curcumin, computational biology, molecular docking, Wnt signaling, in silico},
  selected    = {true}
}
